# Keep the Docker build context small and free of host-only / secret files.
# NOTE: docker/ must NOT be ignored — the Dockerfile COPYs from it.
.git
.gitignore
.github
.gitattributes

# Dependencies + build output are produced inside the image.
node_modules
vendor
public/build
public/hot
public/storage

# Never ship env files into the image (env is injected at runtime by Coolify).
.env
.env.*

# Local SQLite + runtime state.
database/*.sqlite
database/*.sqlite-journal
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/*.key

# Dev-only / not needed at runtime.
tests
.phpunit.result.cache
.phpunit.cache
.idea
.vscode
.claude
*.md
docs

# Other platforms' deploy config.
railway
railway.json
