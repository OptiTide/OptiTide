<?php

/**
 * OptiTide CLI console.
 *
 *   php bin/console migrate               run pending migrations
 *   php bin/console migrate:fresh --seed  drop everything, migrate, seed
 *   php bin/console migrate:rollback      roll back the last batch
 *   php bin/console seed                  run the database seeder
 *   php bin/console key:generate          generate + persist APP_KEY
 *   php bin/console invoices:recurring    generate due recurring invoices
 *   php bin/console invoices:overdue      mark past-due invoices overdue
 */

require __DIR__ . '/bootstrap.php';

use App\Core\Migrator;
use App\Services\Invoices\RecurringBiller;

$command = $argv[1] ?? 'help';
$flags = array_slice($argv, 2);
$out = function (string $message = ''): void {
    fwrite(STDOUT, $message . "\n");
};

$migrator = fn () => new Migrator(BASE_PATH . '/database/migrations');

/**
 * Refuse to run a destructive/demo command anywhere that might be production.
 *
 * Fails CLOSED, and deliberately checks BOTH sources of APP_ENV. Env::get()
 * (app/Core/Env.php:48-60) consults the parsed .env FILE before getenv(), so a .env
 * written inside a container — which `key:generate` does, copying .env.example, and
 * which docs/COOLIFY.md tells you to run there — would shadow Coolify's real
 * APP_ENV=production and quietly re-open the gate. Checking getenv() directly as
 * well means the file cannot lie its way past this.
 */
function guard_local(string $command): void
{
    $candidates = [env('APP_ENV'), getenv('APP_ENV')];

    foreach ($candidates as $value) {
        if (is_string($value) && strtolower(trim($value)) === 'production') {
            fwrite(STDERR, "Refusing to run `{$command}` — APP_ENV is production.\n");
            fwrite(STDERR, "This command creates demo data (logins with the password \"password\") or drops tables.\n");
            fwrite(STDERR, "If you meant to reset live data, use: php bin/console db:reset\n");
            exit(1);
        }
    }
}

try {
    switch ($command) {
        case 'migrate':
            $migrator()->run($out);
            break;

        case 'migrate:rollback':
            $migrator()->rollback($out);
            break;

        case 'migrate:fresh':
            // fresh() DROPS every table, so this is local-only whatever the flags
            // say. Gated exactly like seed:demo.
            guard_local('migrate:fresh');
            $migrator()->fresh($out);
            if (in_array('--seed', $flags, true)) {
                $seeder = require BASE_PATH . '/database/seeds/DatabaseSeeder.php';
                $seeder->run($out);
                $seeder->runDemo($out);
            }
            break;

        case 'seed':
            // REFERENCE data only (catalogue, articles, board structure, backlinks):
            // idempotent and safe on production. This is what SEED_ON_BOOT runs, so
            // a container restart can never reintroduce demo data.
            (require BASE_PATH . '/database/seeds/DatabaseSeeder.php')->run($out);
            break;

        case 'seed:demo':
            // A demo client plus logins whose password is literally "password" — in a
            // PUBLIC repo. Never on production.
            guard_local('seed:demo');
            (require BASE_PATH . '/database/seeds/DatabaseSeeder.php')->runDemo($out);
            break;

        case 'blacklist:check':
            // Scheduled (daily is plenty — listings move slowly). Raises one board
            // card per new listing; clears its guard on delisting.
            $stats = (new App\Services\Seo\BlacklistService())->run();
            $out(sprintf(
                'Checked %d target(s): %d listed (%d new card(s)), %d cleared, %d unavailable.',
                $stats['checked'], $stats['listed'], $stats['new_cards'], $stats['cleared'], $stats['unavailable']
            ));
            break;

        case 'import:clients':
        case 'import:invoices':
            // DRY RUN unless --commit. Everything it creates is silent (notify=false,
            // and unpaid backdated rows are exempt from the chase), so importing
            // history can never email a client an invoice they settled years ago.
            $file = $flags[0] ?? null;
            if (! $file || str_starts_with($file, '--')) {
                $out('Usage: php bin/console ' . $command . ' <file.csv> [--commit]');
                $out('');
                $out('  Without --commit it only reports what it WOULD do. Nothing is written.');
                $out('');
                $out('  clients.csv   business_name,contact_name,email,phone,abn,address_line1,');
                $out('                address_locality,address_region,address_postcode,notes,created_at');
                $out('  invoices.csv  client_email,number,description,amount,issue_date,due_date,');
                $out('                paid_date,status');
                $out('');
                $out('  amount is DOLLARS and GST-INCLUSIVE. Import clients first.');
                exit(1);
            }

            $importer = require BASE_PATH . '/database/import.php';
            $method = $command === 'import:clients' ? 'clients' : 'invoices';
            exit($importer->{$method}($out, $file, in_array('--commit', $flags, true)));

        case 'db:reset':
            // Clear every client + their data so real clients can start; keeps the
            // marketing site, catalogue, blog and your admin login. Deliberately NOT
            // guarded by APP_ENV — production is exactly where you run it. It guards
            // itself: prints the resolved database, requires typed confirmation, and
            // asserts the KEEP tables survived before committing.
            $exit = (require BASE_PATH . '/database/reset.php')
                ->run($out, in_array('--yes', $flags, true));
            exit($exit);

        case 'key:generate':
            $key = 'base64:' . base64_encode(random_bytes(32));
            set_env_value('APP_KEY', $key);
            $out('APP_KEY set.');
            break;

        case 'invoices:recurring':
            $autoSend = in_array('--send', $flags, true);
            $result = (new RecurringBiller())->run($autoSend);
            $out("Generated {$result['generated']} invoice(s): " . (implode(', ', $result['invoices']) ?: '—'));
            break;

        case 'invoices:overdue':
            $count = (new RecurringBiller())->markOverdue();
            $out("Marked $count invoice(s) overdue.");
            break;

        case 'seo:reports':
            // SEO reports are due at the end of each month — run this on/near the 1st.
            $month = $flags[0] ?? null;
            $made = (new App\Services\Projects\SeoReportService())->generateForMonth($month);
            $out("Created {$made} SEO report card(s) for " . ($month ?: date('F Y')) . '.');
            break;

        case 'clients:suspend-overdue':
            // Suspend clients whose invoices are overdue past the grace period.
            $days = isset($flags[0]) ? (int) $flags[0] : null;
            $r = (new App\Services\Billing\SuspensionService())->run($days);
            $out("Suspended {$r['suspended']} client(s) for overdue invoices.");
            break;

        case 'tickets:import-email':
            // Pull inbound email into the helpdesk (IMAP; needs the imap extension).
            $r = (new App\Services\Support\EmailImportService())->import();
            if (! empty($r['error'])) {
                $out('Email import: ' . $r['error']);
            } else {
                $out("Imported {$r['imported']} email(s) into the helpdesk.");
            }
            break;

        case 'make:admin':
            $email = isset($flags[0]) ? strtolower(trim($flags[0])) : null;
            $password = $flags[1] ?? null;
            $name = $flags[2] ?? 'Administrator';

            if (! $email) {
                $out('Usage: php bin/console make:admin <email> [password] [name]');
                break;
            }

            $existing = App\Models\User::findByEmail($email);
            if ($existing) {
                $update = ['role' => 'admin', 'status' => 'active'];
                if ($password) {
                    $update['password_hash'] = password_hash($password, PASSWORD_DEFAULT);
                }
                App\Models\User::updateById($existing['id'], $update);
                $out("Promoted $email to admin." . ($password ? ' Password updated.' : ''));
            } elseif (! $password) {
                $out("No user with that e-mail. To create one, pass a password:");
                $out("  php bin/console make:admin $email <password> [name]");
            } else {
                App\Models\User::create([
                    'name'          => $name,
                    'email'         => $email,
                    'password_hash' => password_hash($password, PASSWORD_DEFAULT),
                    'role'          => 'admin',
                    'status'        => 'active',
                ]);
                $out("Created admin account: $email");
            }
            break;

        default:
            $out('OptiTide console. Available commands:');
            $out('  migrate | migrate:fresh [--seed] | migrate:rollback | seed');
            $out('  key:generate');
            $out('  make:admin <email> [password] [name]');
            $out('  invoices:recurring [--send] | invoices:overdue');
    }
} catch (\Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . "\n" . $e->getTraceAsString() . "\n");
    exit(1);
}

function set_env_value(string $key, string $value): void
{
    $path = BASE_PATH . '/.env';
    if (! is_file($path)) {
        copy(BASE_PATH . '/.env.example', $path);
    }

    $contents = file_get_contents($path);
    $line = $key . '=' . (preg_match('/\s/', $value) ? '"' . $value . '"' : $value);

    if (preg_match('/^' . preg_quote($key, '/') . '=.*$/m', $contents)) {
        $contents = preg_replace('/^' . preg_quote($key, '/') . '=.*$/m', $line, $contents);
    } else {
        $contents .= "\n" . $line . "\n";
    }

    file_put_contents($path, $contents);
}
