# =============================================================================
# OptiTide — Coolify environment variables.
#
# Set these in the Coolify Docker Compose resource's "Environment Variables"
# panel (NOT committed). docker-compose.yaml interpolates them into every
# service. Plain values only — no ${{...}} reference syntax (that's Railway).
#
# The VITE_* values are passed as BUILD ARGS by the compose file, derived from
# APP_NAME + the REVERB_* vars below — you do not set VITE_* separately.
# =============================================================================

APP_NAME=OptiTide
APP_KEY=                                 # php artisan key:generate --show
APP_URL=https://app.your-domain.com      # the web service's public domain (https)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12
LOG_LEVEL=warning

# --- Database: paste your Coolify-managed Postgres connection URL ------------
# In Coolify, open the Postgres resource → copy the "Postgres URL" (internal).
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME
DB_URL=

# --- Redis (optional) — leave blank to run on database drivers --------------
# REDIS_URL=redis://:password@host:6379
REDIS_CLIENT=phpredis
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# --- S3 (private artifacts, contract PDFs, backups) -------------------------
FILESYSTEM_DISK=s3
FILESYSTEM_PRIVATE_DISK=s3
SIGNATURES_DISK=s3
BACKUP_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
# AWS_ENDPOINT=                          # set for S3-compatible providers (R2, MinIO)
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Reverb (websockets) ----------------------------------------------------
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.your-domain.com           # the reverb service's public domain
REVERB_PORT=443
REVERB_SCHEME=https

# --- Mail -------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@optitide.io

# --- Payments (Stripe) ------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=                   # webhook 503s until this is set
CASHIER_CURRENCY=aud
STRIPE_AUTOMATIC_TAX=false               # only after configuring Stripe Tax (inclusive)

# --- AI (Claude) ------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=high

# --- Social login (optional) ------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.your-domain.com/client/oauth/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://app.your-domain.com/client/oauth/callback/github

# --- Optional integrations (no-op when unset) -------------------------------
GITHUB_TOKEN=
GITHUB_OWNER=
WHM_HOST=
WHM_USERNAME=
WHM_API_TOKEN=

# --- Company / AU tax invoice (GST is inclusive) ----------------------------
COMPANY_LEGAL_NAME=
COMPANY_ABN=
COMPANY_EMAIL=hello@optitide.io
COMPANY_ADDRESS_LINE1=
COMPANY_ADDRESS_LOCALITY=
COMPANY_ADDRESS_REGION=
COMPANY_ADDRESS_POSTCODE=
COMPANY_ADDRESS_COUNTRY=AU
COMPANY_GST_REGISTERED=true
COMPANY_GST_BASIS_POINTS=1000
