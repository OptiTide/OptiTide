# =============================================================================
# OptiTide — production environment (Railway).
# Set these as service variables. Values like ${{Postgres.DATABASE_URL}} are
# Railway reference variables — replace "Postgres"/"Redis" with your actual
# plugin service names. Variables marked (BUILD) must exist during `npm run
# build`; Railway injects service vars at build time, so setting them normally
# is sufficient. Do NOT commit real secrets — this file is a template.
# =============================================================================

APP_NAME=OptiTide                       # (BUILD) baked into VITE_APP_NAME below
APP_ENV=production
APP_KEY=                                # php artisan key:generate --show, then paste
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app # the web service's public domain (https)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

# Logs go to stdout/stderr for Railway's log drain (no persistent disk).
LOG_CHANNEL=stderr
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# --- Database (managed Postgres) --------------------------------------------
DB_CONNECTION=pgsql
DB_URL=${{Postgres.DATABASE_URL}}
# DB_SSLMODE=require                     # if the provider requires TLS

# --- Redis (managed) --------------------------------------------------------
# Redis is optional: the app defaults to database-backed cache/queue/session and
# works without it. To adopt Redis, provision the plugin, set REDIS_URL, flip the
# drivers below, and add ext-redis to the image (RAILPACK_PHP_EXTENSIONS=redis)
# or set REDIS_CLIENT=predis and require predis/predis.
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_CLIENT=phpredis

# --- Drivers ----------------------------------------------------------------
# Start on database drivers (zero extra infra). Switch to redis once Redis + the
# extension are in place.
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true              # HTTPS-only cookies (behind trusted proxy)

# --- Filesystem: private artifacts must NOT live on the ephemeral container --
# Intake uploads + generated SEO reports move to S3 so the worker and web share
# them and they survive redeploys.
FILESYSTEM_DISK=s3
FILESYSTEM_PRIVATE_DISK=s3
SIGNATURES_DISK=s3                      # signed contract PDFs
BACKUP_DISK=s3                          # spatie/laravel-backup archives
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Broadcasting / Reverb (websockets) -------------------------------------
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_SERVER_HOST=0.0.0.0              # container bind (see railway/reverb.sh)
REVERB_SERVER_PORT=8080
REVERB_HOST=your-reverb.up.railway.app  # the Reverb service's public domain
REVERB_PORT=443                         # browser connects over the edge (wss/443)
REVERB_SCHEME=https
# (BUILD) exposed to the browser bundle — must be set when `npm run build` runs.
# Use Railway's ${{VAR}} reference form (NOT shell ${VAR}): Railway resolves
# ${{...}} at build + deploy; a literal ${VAR} would be baked into the JS bundle
# verbatim and the Reverb handshake would fail.
VITE_APP_NAME=${{APP_NAME}}
VITE_REVERB_APP_KEY=${{REVERB_APP_KEY}}
VITE_REVERB_HOST=${{REVERB_HOST}}
VITE_REVERB_PORT=${{REVERB_PORT}}
VITE_REVERB_SCHEME=${{REVERB_SCHEME}}

# --- Mail (configure a real transport) --------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@optitide.io"
MAIL_FROM_NAME=${{APP_NAME}}

# --- Payments (Stripe) — webhook fails closed until the secret is set --------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=aud

# --- AI (Claude) — falls back to FakeClaudeClient without a key -------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=high

# --- Social login (config-gated; buttons hidden without client IDs) ---------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${{APP_URL}}/client/oauth/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=${{APP_URL}}/client/oauth/callback/github

# --- Optional integrations (all fail-closed / no-op when unset) -------------
GITHUB_TOKEN=
GITHUB_OWNER=
WHM_HOST=
WHM_USERNAME=
WHM_API_TOKEN=

# --- Railpack build controls ------------------------------------------------
# Disable Railpack's auto-migrate on EVERY service; the web service migrates via
# its pre-deploy command (railway/release.sh) instead.
RAILPACK_SKIP_MIGRATIONS=1
# If adopting Redis, also install the extension in the image:
# RAILPACK_PHP_EXTENSIONS=redis
