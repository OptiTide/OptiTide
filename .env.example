# ---------------------------------------------------------------------------
# OptiTide CRM — environment
# Copy to .env and fill in. Never commit .env.
# ---------------------------------------------------------------------------

APP_NAME="OptiTide"
APP_ENV=local              # local | production
APP_DEBUG=true             # false in production
APP_URL=http://localhost:8000
APP_KEY=                   # generate with: php bin/console key:generate
APP_TIMEZONE=Australia/Perth

# --- Database -------------------------------------------------------------
# local dev: sqlite (zero setup). production (Coolify): pgsql
DB_CONNECTION=sqlite
DB_DATABASE=database/optitide.sqlite
# For PostgreSQL, set DB_CONNECTION=pgsql and either DATABASE_URL, or:
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=optitide
DB_PASSWORD=
DB_SCHEMA=public
# DB_SSLMODE=require
# Managed Postgres one-liner (overrides the DB_* values, selects pgsql):
# DATABASE_URL=postgres://user:pass@host:5432/optitide

# --- Redis (sessions / cache / rate limiting) -----------------------------
# Uses the pure-PHP predis client (no phpredis extension needed).
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Drivers — local dev keeps file; production can use redis.
SESSION_DRIVER=file        # file | redis
SESSION_LIFETIME=120       # minutes
CACHE_DRIVER=file          # file | redis | array

# --- Mail (Resend) --------------------------------------------------------
MAIL_DRIVER=resend         # resend | log
RESEND_API_KEY=
MAIL_FROM_ADDRESS=Hello@OptiTide.io
MAIL_FROM_NAME="OptiTide"
MAIL_REPLY_TO=Hello@OptiTide.io

# --- Company / AU tax identity -------------------------------------------
COMPANY_LEGAL_NAME="OptiTide"
COMPANY_ABN=
COMPANY_EMAIL=Hello@OptiTide.io
COMPANY_PHONE=
COMPANY_ADDRESS_LINE1=
COMPANY_ADDRESS_LOCALITY=
COMPANY_ADDRESS_REGION=
COMPANY_ADDRESS_POSTCODE=
COMPANY_ADDRESS_COUNTRY=Australia

# GST is INCLUSIVE in AU prices. GST component = total / 11 (10%).
COMPANY_GST_REGISTERED=true
COMPANY_GST_BASIS_POINTS=1000
CURRENCY=AUD

# --- Payments -------------------------------------------------------------
# PayID (bank transfer). type: mobile | email | abn
PAYID_ENABLED=true
PAYID_TYPE=mobile
PAYID_VALUE=
PAYID_ACCOUNT_NAME="OptiTide"
# Optional BSB/account fallback shown alongside PayID
BANK_BSB=
BANK_ACCOUNT_NUMBER=

# Payoneer payment links.
# manual: paste a Payoneer request link per invoice (works today, no API).
# api:    call the Payoneer API to mint a link (needs onboarding + creds).
PAYONEER_ENABLED=true
PAYONEER_MODE=manual
PAYONEER_API_KEY=
PAYONEER_PROGRAM_ID=

# --- Branding -------------------------------------------------------------
BRAND_ACCENT="#FF6A00"
BRAND_ACCENT_DARK="#E85F00"
